<%@ page import="java.sql.*" %>
<%@ page session="true" %>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Admin Panel</title>
<style>
body{font-family:Arial,sans-serif;background:#f2f2f2;padding:20px;}
h1{text-align:center;color:#333;}
table{width:100%;border-collapse:collapse;margin-top:20px;}
th,td{border:1px solid #ccc;padding:12px;text-align:center;}
th{background:#0d6efd;color:white;}
img{width:100px;height:70px;object-fit:cover;border-radius:5px;}
.delete-btn{background:red;color:white;padding:5px 10px;border:none;border-radius:5px;cursor:pointer;}
.delete-btn:hover{opacity:0.8;}
</style>
</head>
<body>
<h1>Admin Panel — Manage Items</h1>

<table>
<tr>
<th>ID</th>
<th>Item Name</th>
<th>Location</th>
<th>Image</th>
<th>Action</th>
</tr>

<%
Class.forName("com.mysql.cj.jdbc.Driver");
Connection con = DriverManager.getConnection(
    "jdbc:mysql://localhost:3306/users_10jan26","root","abc123"
);

PreparedStatement ps = con.prepareStatement("SELECT * FROM items");
ResultSet rs = ps.executeQuery();

while(rs.next()){
%>
<tr>
<td><%= rs.getInt("id") %></td>
<td><%= rs.getString("item_name") %></td>
<td><%= rs.getString("location") %></td>
<td><img src="<%= rs.getString("image_path") %>"></td>
<td>
    <form method="post" action="DeleteItem.jsp" onsubmit="return confirm('Are you sure?');">
        <input type="hidden" name="id" value="<%= rs.getInt("id") %>">
        <button class="delete-btn">Delete</button>
    </form>
</td>
</tr>
<%
}
con.close();
%>

</table>
</body>
</html>
